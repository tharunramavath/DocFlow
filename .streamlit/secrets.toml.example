# Streamlit Cloud Secrets Template
# ================================
# Copy this file to secrets.toml for local development, OR set these values
# via the Streamlit Cloud dashboard (Settings → Secrets) when deployed.
#
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# ─── Required ────────────────────────────────────────────────────────────────
BREVO_API_KEY = "your_brevo_api_key_here"

# ─── Optional ────────────────────────────────────────────────────────────────
# All other settings (sender name, email, template, etc.) are configured
# through the app's Settings page and stored in config/config.json.
